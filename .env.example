# FastAPI MCP Server — Environment Variables Example
# Copy this file to .env and fill in your actual values.
# IMPORTANT: Never commit .env with real secrets to the repository.

# Descope project credentials (required for JWT authentication)
# Get these from your Descope Console: https://app.descope.com/
DESCOPE_PROJECT_ID=<your_descope_project_id>
DESCOPE_API_BASE_URL=https://api.descope.com
